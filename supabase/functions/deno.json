{
  "imports": {
    "@supabase/supabase-js": "npm:@supabase/supabase-js@^2.89.0"
  },
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "strict": false
  },
  "tasks": {
    "serve": "deno run --allow-all --allow-net --allow-env --allow-read"
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-explicit-any"
      ]
    }
  }
}

create or replace function public.get_random_healing_message()
returns table (
  message text,
  discord_id text,
  username text,
  avatar_url text
)
language sql
security definer
set search_path = public
as $$
  select
    hm.message,
    p.discord_id,
    p.username,
    p.avatar_url
  from public.healing_messages hm
  left join public.profiles p on p.id = hm.author_id
  where hm.status = 'approved'
  order by random()
  limit 1;
$$;


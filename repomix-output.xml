/** Parse Thai timestamp "DD/MM/YYYY HH:mm:ss" or other formats to ISO string */
function parseTimestamp(raw: string): string | null {
  if (!raw) return null;
  const parts = raw.split(" ");
  if (parts.length >= 2) {
    const dateParts = parts[0].split("/");

      }

      if (supabaseImagePaths.length > 0) {
        const { error: storageError } = await supabase.storage
          .from('slip-images')
          .remove(supabaseImagePaths);
        
        if (storageError) {
          console.error('Failed to delete images:', storageError);
        }

@layer base {
  * {
    @apply border-border;
  }

  /* Theme transition - smooth fade effect */
  html {
    transition: background-color 0.4s ease, color 0.3s ease;
  }

  html.theme-transitioning,
  html.theme-transitioning *,
  html.theme-transitioning *::before,
  html.theme-transitioning *::after {
    transition: background-color 0.4s ease, 
                color 0.3s ease, 
                border-color 0.3s ease,
                box-shadow 0.3s ease,
                fill 0.3s ease,
                stroke 0.3s ease !important;
  }

  body {
    @apply bg-background text-foreground font-sans antialiased;
    font-size: 15px;
  }

  h1, h2, h3, h4, h5, h6 {
    @apply font-display font-bold;
  }
}

@layer components {
  /* Bear Café Card Styles */
  .bear-card {
    @apply bg-card rounded-2xl border border-border shadow-sm hover:shadow-md transition-shadow duration-300;
  }

  .bear-card-interactive {
    @apply bear-card cursor-pointer hover:border-primary/30 hover:scale-[1.02] transition-all duration-300;
  }

  /* Bear Button Glow */
  .bear-glow {
    @apply relative overflow-hidden;
  }

  .bear-glow::before {
    content: '';
    @apply absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full;
    animation: shimmer 2s infinite;
  }

  @keyframes shimmer {
    100% {
      transform: translateX(100%);
    }
  }

  /* Bear Badge */
  .bear-badge {
    @apply inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm font-medium bg-secondary text-secondary-foreground;
  }

  /* Floating animation for decorative elements */
  .bear-float {
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  /* Bear paw cursor hint */
  .bear-paw {
    @apply cursor-pointer transition-transform hover:scale-110 active:scale-95;
  }
}

@layer utilities {
  /* Background patterns */
  .bg-pattern-dots {
    background-image: radial-gradient(hsl(var(--border)) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  .bg-pattern-grid {
    background-image: 
      linear-gradient(hsl(var(--border)) 1px, transparent 1px),
      linear-gradient(90deg, hsl(var(--border)) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  /* Gradient utilities */
  .gradient-bear {
    background: linear-gradient(135deg, hsl(var(--primary)) 0%, hsl(var(--bear-light)) 100%);
  }

  .gradient-honey {
    background: linear-gradient(135deg, hsl(var(--honey)) 0%, hsl(var(--peach)) 100%);
  }

  .gradient-cream {
    background: linear-gradient(180deg, hsl(var(--cream)) 0%, hsl(var(--latte)) 100%);
  }

  /* Text gradient */
  .text-gradient-bear {
    @apply bg-clip-text text-transparent;
    background-image: linear-gradient(135deg, hsl(var(--primary)) 0%, hsl(var(--bear-light)) 100%);
  }

  /* Slow bounce animation for loading states */
  .animate-bounce-slow {
    animation: bounce-slow 2s ease-in-out infinite;
  }

  @keyframes bounce-slow {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-12px);
    }
  }

  /* Gentle bounce animation */
  .animate-bounce-gentle {
    animation: bounce-gentle 1.5s ease-in-out infinite;
  }

  @keyframes bounce-gentle {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }

  /* Animated gradient for banner fallback */
  @keyframes gradient-slow {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  .animate-gradient-slow {
    background-size: 200% 200%;
    animation: gradient-slow 8s ease infinite;
  }

  /* Particle burst animation for button effects */
  .animate-particle-burst {
    animation: particle-burst 0.6s ease-out forwards;
  }

  @keyframes particle-burst {
    0% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(0);
    }
    50% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      transform: translate(calc(-50% + var(--tx)), calc(-50% + var(--ty))) scale(1.5);
    }
  }

  /* Shimmer effect for buttons */
  .animate-shimmer {
    animation: shimmer 3s ease-in-out infinite;
  }

  @keyframes shimmer {
    0% {
      transform: translateX(-100%);
    }
    50%, 100% {
      transform: translateX(100%);
    }
  }

  /* Glow ring animation */
  .animate-glow-ring {
    animation: glow-ring 2s ease-in-out infinite;
  }

  @keyframes glow-ring {
    0%, 100% {
      box-shadow: 0 0 0 0 hsl(var(--primary) / 0.4);
    }
    50% {
      box-shadow: 0 0 0 8px hsl(var(--primary) / 0);
    }
  }

  /* Pulse slow animation */
  .animate-pulse-slow {
    animation: pulse-slow 3s ease-in-out infinite;
  }

  @keyframes pulse-slow {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.9;
      transform: scale(1.02);
    }
  }

  /* Slide up animation */
  .animate-slide-up {
    animation: slide-up 0.4s ease-out;
  }

  @keyframes slide-up {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Scale up animation */
  .animate-scale-up {
    animation: scale-up 0.3s ease-out;
  }

  @keyframes scale-up {
    0% {
      opacity: 0;
      transform: scale(0.9);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* Staggered children animation helper */
  .stagger-children > * {
    animation: fade-in 0.4s ease-out both;
  }
  
  .stagger-children > *:nth-child(1) { animation-delay: 0ms; }
  .stagger-children > *:nth-child(2) { animation-delay: 50ms; }
  .stagger-children > *:nth-child(3) { animation-delay: 100ms; }
  .stagger-children > *:nth-child(4) { animation-delay: 150ms; }
  .stagger-children > *:nth-child(5) { animation-delay: 200ms; }
  .stagger-children > *:nth-child(6) { animation-delay: 250ms; }

  @keyframes fade-in {
    0% {
      opacity: 0;
      transform: translateY(10px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Hover lift effect */
  .hover-lift {
    @apply transition-all duration-300;
  }
  
  .hover-lift:hover {
    @apply -translate-y-1 shadow-lg;
  }

  /* Card hover glow */
  .card-glow {
    @apply transition-all duration-300;
  }
  
  .card-glow:hover {
    box-shadow: 0 0 20px hsl(var(--primary) / 0.15);
  }
}

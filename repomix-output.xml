    emoji: { id: '1451219108531277826', name: '7759pepebeg', animated: true },
  },
};

export function normalizeSessionMode(sessionMode?: string | null): SessionMode {
  return sessionMode === 'voice_room' ? 'voice_room' : 'dm';
}


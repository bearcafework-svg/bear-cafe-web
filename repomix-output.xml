    try {
      const { data } = await supabase
        .from('profiles')
        .select('discord_id, username, discord_username, avatar_url')
        .in('discord_id', uniqueIds);
      if (data) {
        const map = new Map<string, DiscordProfile>();
        data.forEach((p) => map.set(p.discord_id, p));

                          <p className="text-sm leading-snug max-h-24 overflow-y-auto pr-1 break-words">{r.warningMessage}</p>
                        </div>
                      )}

                      {/* Punishment with inline link */}
                      {r.punishment && (
                        <div className="flex items-center gap-2 text-sm">

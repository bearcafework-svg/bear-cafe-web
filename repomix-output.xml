          >
            <ArrowLeft className="w-5 h-5 sm:w-6 sm:h-6" />
          </Button>
          <div className="min-w-0">
            <h1 className="font-display font-bold text-lg sm:text-xl text-foreground truncate">📜 ประวัติแมตช์</h1>
